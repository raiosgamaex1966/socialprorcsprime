# ============================================================
# CONFIGURAÇÃO SUPABASE — Social Pro
# ============================================================
# Encontre todas as chaves em:
# https://supabase.com/dashboard/project/SEU_PROJECT_ID/settings/api
#
# Substitua "SEU_PROJECT_ID" pelo Reference ID do seu projeto
# (ex: uavfkztwhugxercqbvxs)
# ============================================================

# Chave pública (anon key) do Supabase — usada no lado do servidor (SSR/Edge Functions).
# Encontre em: Dashboard > Settings > API > Project API keys > anon/public
SUPABASE_PUBLISHABLE_KEY="sb_publishable_SqVuvU67dhJyyfT4hQBdkA_zS8IsiaD"

# URL base do projeto Supabase — usada no lado do servidor (SSR/Edge Functions).
# Encontre em: Dashboard > Settings > API > Project URL
SUPABASE_URL="https://izjrszlmqveaxvzswtdi.supabase.co"

# ID do projeto Supabase (Reference ID) — usado para construir URLs dinâmicas no frontend.
# Encontre em: Dashboard > Settings > General > Reference ID
VITE_SUPABASE_PROJECT_ID="izjrszlmqveaxvzswtdi"

# Chave pública (anon key) do Supabase — exposta ao frontend via prefixo VITE_.
# Mesma chave que SUPABASE_PUBLISHABLE_KEY, mas acessível pelo Vite no browser.
# Encontre em: Dashboard > Settings > API > Project API keys > anon/public
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_SqVuvU67dhJyyfT4hQBdkA_zS8IsiaD"

# URL base do projeto Supabase — exposta ao frontend via prefixo VITE_.
# Mesma URL que SUPABASE_URL, mas acessível pelo Vite no browser.
# Encontre em: Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL="https://izjrszlmqveaxvzswtdi.supabase.co"

# Modo demonstração — quando "true", habilita dados de exemplo e bypasses de autenticação.
# Defina como "false" em produção.
VITE_DEMO_MODE=true